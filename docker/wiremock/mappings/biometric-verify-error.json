{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/biometric-service/v1/verify",
    "bodyPatterns": [
      {
        "matchesJsonPath": {
          "expression": "$.authSessionToken",
          "matches": ".*failure$"
        }
      }
    ]
  },
  "response": {
    "status": 406,
    "bodyFileName": "biometric-service/verify-error.json",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}